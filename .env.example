# Required
DATABASE_URL=postgres://hydrahouse:hydrahouse@localhost:5432/hydrahouse

# API server
HH_LISTEN_ADDR=0.0.0.0:3000
HH_WS_BASE_URL=ws://localhost:3000

# Orchestrator: "docker" (local dev) or "kubernetes" (production)
HH_MODE=docker
HH_K8S_NAMESPACE=hydrahouse
HH_DATA_DIR=.hydrahouse-data

# Cardano / Hydra
HH_HYDRA_NODE_IMAGE=ghcr.io/cardano-scaling/hydra-node:1.2.0

# Per-network Blockfrost project IDs
HH_BLOCKFROST_PROJECT_ID_PREPROD=
HH_BLOCKFROST_PROJECT_ID_PREVIEW=
HH_BLOCKFROST_PROJECT_ID_MAINNET=

# Per-network platform wallet signing keys (cborHex)
HH_PLATFORM_WALLET_SK_PREPROD=
HH_PLATFORM_WALLET_SK_PREVIEW=
HH_PLATFORM_WALLET_SK_MAINNET=

# Per-network platform wallet addresses
HH_PLATFORM_WALLET_ADDRESS_PREPROD=
HH_PLATFORM_WALLET_ADDRESS_PREVIEW=
HH_PLATFORM_WALLET_ADDRESS_MAINNET=

# Encryption key for participant key material at rest (32-byte hex string)
HH_ENCRYPTION_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=736208371429-6gungtfe3nrul24m2rqhm83ccv09i0jh.apps.googleusercontent.com

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS: comma-separated allowed origins (defaults to localhost:5173,localhost:3000 for dev)
# HH_CORS_ORIGINS=https://dashboard.hydrahouse.io,https://hydrahouse.io
